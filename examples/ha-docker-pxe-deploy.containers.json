[
  {
    "name": "rgpiod",
    "image": "local/rgpiod:latest",
    "source": {
      "type": "git",
      "url": "https://github.com/<owner>/<repo>.git",
      "dockerfile": "Dockerfile"
    },
    "env": {
      "RGPIOD_PORT": "8889",
      "RGPIOD_LOCAL_ONLY": "0"
    },
    "ports": [
      "8889:8889"
    ],
    "devices": [
      "/dev/gpiochip0:/dev/gpiochip0"
    ]
  }
]
